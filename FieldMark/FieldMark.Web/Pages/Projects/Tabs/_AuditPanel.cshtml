<div id="project-detail-tab-content" role="tabpanel" aria-labelledby="tab-audit" tabindex="-1" autofocus>
  <ul id="audit-log" role="list" aria-live="polite">
    @await Html.PartialAsync("Projects/_AuditLogItems", (object)Model)
    @if (Model.AuditRows.Count == 0 && !Model.SuppressAuditEmptyState)
    {
      <li class="alert alert-info" role="status">No audit entries recorded for this project yet.</li>
    }
  </ul>
</div>
