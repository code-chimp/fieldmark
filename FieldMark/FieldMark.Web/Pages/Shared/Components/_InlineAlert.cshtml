@* Contract: docs/reference/component-canonical-examples.md *@
@model dynamic
@functions {
    public record InlineAlertViewModel(string Severity, string Title, string Message, string? Meta);

    private static string S(object? value) => Convert.ToString(value, System.Globalization.CultureInfo.InvariantCulture) ?? "";
    private static string AlertClass(string severity) => severity is "danger" or "warning" or "info" or "success" ? $"alert-{severity}" : "alert-unknown";
    private static string Role(string severity) => severity is "danger" or "warning" ? "alert" : "status";
}
@{
    var severity = S(Model.Severity).ToLowerInvariant();
    var title = S(Model.Title);
    var message = S(Model.Message);
    var meta = S(Model.Meta);
    var icon = severity is "danger" or "warning" ? "warning" : severity == "success" ? "success" : "info";
}
<div class="alert @AlertClass(severity)" role="@Role(severity)">
  @if (icon == "warning")
  {
    <svg aria-hidden="true" class="alert-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m21.73 18-8-14a2 2 0 0 0-3.46 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"></path><path d="M12 9v4"></path><path d="M12 17h.01"></path></svg>
  }
  else if (icon == "success")
  {
    <svg aria-hidden="true" class="alert-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"></path></svg>
  }
  else
  {
    <svg aria-hidden="true" class="alert-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><path d="M12 16v-4"></path><path d="M12 8h.01"></path></svg>
  }
  <strong class="alert-title">@title</strong>
  <p class="alert-message">@message</p>
  @if (!string.IsNullOrWhiteSpace(meta))
  {
    <p class="alert-meta">@meta</p>
  }
</div>
