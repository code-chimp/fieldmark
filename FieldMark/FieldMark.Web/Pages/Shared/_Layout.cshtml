<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"] - FieldMark</title>
    <link rel="stylesheet" href="~/vendor/fieldmark.css" asp-append-version="true"/>
    <script src="~/vendor/ag-grid/35.2.1/ag-grid-community.min.js"></script>
</head>
<body>
<a href="#main-content" class="skip-link">Skip to main content</a>

<header>
    <nav aria-label="Main">
        <a asp-area="" asp-page="/Index">FieldMark</a>
    </nav>
</header>

<main id="main-content">
    <partial name="_FlashRegion" />
    @RenderBody()
</main>

<footer>
    <p>&copy; 2026 FieldMark</p>
</footer>

<script src="~/vendor/htmx/htmx.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>

@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
