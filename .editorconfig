# FieldMark monorepo — root EditorConfig
# Establishes universal defaults for all files.
# Stack-specific overrides live in each project subdirectory and cascade on top of these.
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# Markdown: trailing spaces are intentional (two spaces = hard line break in CommonMark)
[*.md]
trim_trailing_whitespace = false

# Makefiles require hard tabs — spaces break them
[{Makefile,makefile,GNUmakefile}]
indent_style = tab
indent_size = 4

# SQL — init scripts and migrations
[*.sql]
indent_size = 2

# YAML — Docker Compose, CI, GitHub Actions
[*.{yml,yaml}]
indent_size = 2

# JSON — package.json, tsconfig, launch.json, etc.
[*.json]
indent_size = 2

# TOML — pyproject.toml, Cargo.toml
[*.toml]
indent_size = 2

# XML — only shared infrastructure files; MSBuild XML is overridden per project
[*.xml]
indent_size = 2

# Shell scripts
[*.sh]
indent_size = 2
