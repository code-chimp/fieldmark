{
  "name": "fieldmark-e2e",
  "version": "1.0.0",
  "description": "Shared Playwright E2E harness for FieldMark backends",
  "keywords": [
    "playwright",
    "e2e",
    "testing",
    "harness",
    "fieldmark"
  ],
  "author": {
    "name": "Tim Goshinski",
    "email": "tim@code-chimp.com",
    "url": "https://code-chimp.com"
  },
  "license": "MIT",
  "type": "commonjs",
  "main": "index.js",
  "scripts": {
    "test:e2e": "playwright test",
    "test:e2e:dotnet": "playwright test --project=dotnet",
    "test:e2e:django": "playwright test --project=django",
    "test:e2e:fiber": "playwright test --project=fiber",
    "test:e2e:all": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:codegen": "playwright codegen",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "ci:check": "biome ci ."
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.14",
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "dotenv": "^16.6.1"
  }
}
